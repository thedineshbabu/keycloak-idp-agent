# Copy this file to .env and fill in your values.
# The app runs in mock/local-dev mode when optional vars are not set.

# ── LLM API Keys ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iam_db
DB_USER=iam_user
DB_PASSWORD=

# ── IAM Service ───────────────────────────────────────────────────────────────
IAM_SERVICE_BASE_URL=http://localhost:8080/api/v1

# ── Core API (/v2/clients/customAttributes) ──────────────────────────────────
# Base URL for the Core API (no trailing slash)
CORE_API_BASE_URL=https://your-core-api-host
# JWT bearer token used as fallback for scheduled jobs (paste without "Bearer " prefix)
CORE_API_BEARER_TOKEN=

# ── Keycloak SSO (backend JWT validation) ────────────────────────────────────
# Set KEYCLOAK_ENABLED=false to bypass token validation in local dev only.
KEYCLOAK_ENABLED=true
KEYCLOAK_URL=https://your-keycloak-server
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=your-client-id

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_KEYCLOAK_URL=https://your-keycloak-server/realms/your-realm
VITE_KEYCLOAK_CLIENT=your-client-id
