# Copy this file to .env and fill in your values.
# The app runs in mock/local-dev mode when optional vars are not set.

# ── LLM API Keys ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Agent Guardrails ─────────────────────────────────────────────────────────
# Which LLM provider the backend uses for all requests (openai | gemini)
DEFAULT_LLM_PROVIDER=gemini
# Maximum chat/policy queries a single user can make per day (0 = unlimited)
DAILY_QUERY_LIMIT=10

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iam_db
DB_USER=iam_user
DB_PASSWORD=

# ── IAM Service ───────────────────────────────────────────────────────────────
IAM_SERVICE_BASE_URL=http://localhost:8080/api/v1

# ── Core API (clients, products, engagements) ─────────────────────────────────
# Base URL for the Core API (no trailing slash)
CORE_API_BASE_URL=https://your-core-api-host
# JWT bearer token used as fallback for scheduled jobs (paste without "Bearer " prefix)
CORE_API_BEARER_TOKEN=

# ── IAM API (users, roles, shadow users, communities) ────────────────────────
IAM_API_BASE_URL=https://your-iam-api-host

# ── Keycloak SSO (backend JWT validation) ────────────────────────────────────
# Set KEYCLOAK_ENABLED=false to bypass token validation in local dev only.
KEYCLOAK_ENABLED=true
KEYCLOAK_URL=https://your-keycloak-server
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=your-client-id

# ── Keycloak Admin Service Account (Policy Query Engine) ─────────────────────
# Client with service accounts enabled and realm-management roles assigned.
# Required roles on the service account: view-realm, view-clients, view-users,
# query-users, query-clients (all under realm-management).
KEYCLOAK_ADMIN_CLIENT_ID=your-service-account-client-id
KEYCLOAK_ADMIN_CLIENT_SECRET=your-client-secret

# ── Datadog (optional — omit to disable observability tools) ─────────────────
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_KEYCLOAK_URL=https://your-keycloak-server
VITE_KEYCLOAK_REALM=your-realm
VITE_KEYCLOAK_CLIENT=your-client-id
